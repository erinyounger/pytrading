{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo 'graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.' || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "_templateId": "ccw-coordinator-tracker",
        "hooks": [
          {
            "type": "command",
            "command": "ccw hook template exec ccw-coordinator-tracker --stdin"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "_templateId": "ccw-coordinator-skill-context",
        "hooks": [
          {
            "type": "command",
            "command": "ccw hook template exec ccw-coordinator-skill-context --stdin"
          }
        ]
      }
    ]
  }
}